# Propr API key (https://www.propr.xyz — create an account, then generate an API key
# from the dashboard; it must start with `pk_live_` or `pk_test_`).
PROPR_API_KEY=pk_live_your_key_here

# Telegram bot token (talk to @BotFather on Telegram: /newbot → follow the prompts,
# BotFather returns a token like `123456789:AA...`).
TELEGRAM_BOT_TOKEN=123456789:your_telegram_bot_token_here

# Telegram chat id of the account that is allowed to control this bot
# (message @userinfobot on Telegram to get your numeric chat id).
TELEGRAM_CHAT_ID=123456789

# Groq API key (https://console.groq.com/keys — sign in, create a key, copy it here).
GROQ_API_KEY=gsk_your_groq_key_here
